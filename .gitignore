# API keys — never commit
.env

# Claude Code internals — not part of the project
.claude/
memory/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
venv2/
.venv/
env/

# Experiment outputs (large, reproducible)
logs/
results/A/
results/B/
results/C/
results/summary.json

# Jupyter
.ipynb_checkpoints/
*.ipynb

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# MLAgentBench workspace artifacts
workspace/

# Submodule runtime artifacts — prevent 'untracked content' in git status
implementation/MLAgentBench/MLAgentBench/benchmarks/*/env/
implementation/MLAgentBench/MLAgentBench/benchmarks/*/work/
implementation/MLAgentBench/
